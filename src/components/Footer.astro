---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-col">
      <span class="logo">CLP</span>
      <p class="footer-tag">Construyendo el ecosistema Web3 de La Plata.</p>
    </div>
    <div class="footer-col">
      <h4>Navegación</h4>
      <a href="#hero">Inicio</a>
      <a href="#historia">Historia</a>
      <a href="#eventos">Eventos</a>
      <a href="#equipo">Equipo</a>
      <a href="#contacto">Contacto</a>
    </div>
    <div class="footer-col">
      <h4>Redes</h4>
      <a href="#">Telegram</a>
      <a href="#">Twitter/X</a>
      <a href="#">LinkedIn</a>
      <a href="#">Instagram</a>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; 2026 Cripto La Plata. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
/* ============ FOOTER ============ */
.footer {
  border-top: 1px solid var(--glass-border);
  padding: 60px 32px 24px;
}
.footer-inner {
  max-width: 1280px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.4fr 1fr 1fr;
  gap: 40px;
  margin-bottom: 40px;
}
.footer-tag { color: var(--text-muted); margin-top: 12px; font-size: 0.9rem; max-width: 280px; }
.footer-col h4 { font-size: 0.95rem; margin-bottom: 14px; }
.footer-col a {
  display: block;
  color: var(--text-muted);
  font-size: 0.85rem;
  margin-bottom: 10px;
  transition: color 0.2s ease;
}
.footer-col a:hover { color: var(--primary); }
.footer-bottom {
  max-width: 1280px;
  margin: 0 auto;
  border-top: 1px solid var(--glass-border);
  padding-top: 20px;
  text-align: center;
  color: var(--text-muted);
  font-size: 0.8rem;
}

@media (max-width: 768px) {
  .footer-inner { grid-template-columns: 1fr; gap: 28px; }
}
</style>
