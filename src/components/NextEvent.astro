---
// src/components/NextEvent.astro

// Esta variable simula si ya tenemos fecha o no. 
// En el futuro, esto podría venir de una base de datos o un CMS.
const isConfirmed = false; 

const eventData = {
  title: "Hackathon CLP 2026",
  date: "18 de Abril, 2026 — 09:00 hs",
  location: "📍 Sede a confirmar, La Plata",
  targetDate: "2026-07-30T09:00:00" // Para el JS del contador más adelante
};
---

<section class="proximo" id="proximo-evento">
  {isConfirmed ? (
    /* CASO A: EVENTO CONFIRMADO (Contador) */
    <div class="proximo-card reveal">
      <div class="proximo-info">
        <span class="badge badge-soft">Próximamente</span>
        <h2>{eventData.title}</h2>
        <p class="proximo-fecha">{eventData.date}</p>
        <p class="proximo-loc">{eventData.location}</p>
        <a href="#" class="btn btn-primary">Reservar Lugar</a>
      </div>
      <div class="proximo-countdown" id="countdown">
        <div class="cd-box"><span class="cd-num" id="cd-days">00</span><span class="cd-label">Días</span></div>
        <div class="cd-box"><span class="cd-num" id="cd-hours">00</span><span class="cd-label">Hs</span></div>
        <div class="cd-box"><span class="cd-num" id="cd-min">00</span><span class="cd-label">Min</span></div>
        <div class="cd-box"><span class="cd-num" id="cd-sec">00</span><span class="cd-label">Seg</span></div>
      </div>
    </div>
  ) : (
    /* CASO B: EN ORGANIZACIÓN */
    <div class="proximo-card sin-fecha reveal">
      <div class="proximo-info">
        <span class="badge badge-soft">🛠️ En organización</span>
        <h2>Estamos armando el próximo evento</h2>
        <p class="proximo-fecha">Ya estamos coordinando sede, agenda y partners.</p>
        <p class="proximo-loc">Sumate a la comunidad para enterarte primero ni bien tengamos fecha.</p>
        <a href="#contacto" class="btn btn-primary">Quiero que me avisen</a>
      </div>
      <div class="proximo-status">
        <div class="status-item">
          <span class="status-dot"></span>
          <div class="status-text"><strong>Fecha</strong><small>En definición</small></div>
        </div>
        <div class="status-item">
          <span class="status-dot"></span>
          <div class="status-text"><strong>Sede</strong><small>Coordinando con partners</small></div>
        </div>
        <div class="status-item">
          <span class="status-dot"></span>
          <div class="status-text"><strong>Cupos</strong><small>Próximamente</small></div>
        </div>
      </div>
    </div>
  )}
</section>

<style>

/* ============ PROXIMO EVENTO ============ */
.proximo { padding: 60px 32px 100px; max-width: 1280px; margin: 0 auto; }
.proximo-card {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 40px;
  align-items: center;
  background: linear-gradient(135deg, rgba(4,255,183,0.08), rgba(213,63,233,0.08));
  border: 1px solid var(--glass-border);
  border-radius: 24px;
  padding: 48px;
  backdrop-filter: blur(10px);
}
.proximo-info h2 { font-size: clamp(1.6rem, 3.5vw, 2.4rem); margin: 12px 0; }
.proximo-fecha, .proximo-loc { color: var(--text-muted); margin-bottom: 8px; }
.proximo-info .btn { margin-top: 20px; }
.badge-soft { animation: pulse 2.4s ease-in-out infinite; }
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.55; }
}

.proximo-countdown {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}
.cd-box {
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  border-radius: 14px;
  padding: 20px 8px;
  text-align: center;
}
.cd-num {
  display: block;
  font-family: var(--font-title);
  font-size: 2rem;
  font-weight: 700;
  background: var(--gradient);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}
.cd-label {
  font-size: 0.75rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 1px;
}

@media (max-width: 768px) {
  .proximo-card { grid-template-columns: 1fr; }
} 

.proximo-card.sin-fecha { grid-template-columns: 1.3fr 1fr; }
.proximo-status { display: flex; flex-direction: column; gap: 14px; }
.status-item {
  display: flex; align-items: center; gap: 14px;
  background: var(--glass-bg); border: 1px solid var(--glass-border);
  border-radius: 14px; padding: 14px 18px;
}
.status-dot {
  width: 10px; height: 10px; border-radius: 50%;
  background: var(--gradient); flex-shrink: 0;
  animation: statusPulse 1.8s ease-out infinite;
}
@keyframes statusPulse {
  0%   { box-shadow: 0 0 0 0 rgba(4,255,183,0.45); }
  70%  { box-shadow: 0 0 0 8px rgba(4,255,183,0); }
  100% { box-shadow: 0 0 0 0 rgba(4,255,183,0); }
}
.status-text { display: flex; flex-direction: column; gap: 2px; }
.status-text strong { font-family: var(--font-title); font-size: 0.95rem; font-weight: 700; }
.status-text small { color: var(--text-muted); font-size: 0.78rem; }

 @media (max-width: 900px) {
    .proximo-card {
      flex-direction: column; /* Apila el contenido verticalmente */
      text-align: center;
      padding: 32px 24px;
    }

    .proximo-info {
      max-width: 100%;
    }

    .proximo-countdown {
      width: 100%;
      justify-content: center;
      gap: 12px;
    }

    .proximo-status {
      width: 100%;
      flex-direction: column; /* Apila los estados en "En organización" */
      gap: 16px;
    }
    
    .cd-box {
      min-width: 70px; /* Hace los cuadros del contador un poco más chicos */
      padding: 12px;
    }
  }

  @media (max-width: 480px) {
    .proximo-countdown {
      display: grid;
      grid-template-columns: 1fr 1fr; /* 2x2 en pantallas muy chicas */
      gap: 10px;
    }
  }

</style>
