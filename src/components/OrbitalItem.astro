---
// src/components/OrbitalItem.astro
const { year, angle, active = false } = Astro.props;
---

<button 
  class={`orbital-item ${active ? 'active' : ''}`} 
  data-year={year} 
  style={`--angle:${angle}deg`}
>
  <span class="orbital-year">{year === 'actualidad' ? 'Hoy' : year}</span>
</button>

<style>
  .orbital-item {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 64px;
    height: 64px;
    margin: -32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: blur(8px);
    color: var(--text-muted);
    font-family: var(--font-title);
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
    transition: border-color 0.25s ease, color 0.25s ease, background 0.25s ease, transform 0.25s ease;
    transform: rotate(var(--angle)) translate(var(--radius));
  }

  .orbital-item:hover {
    color: var(--white);
    border-color: var(--primary);
  }

  .orbital-item.active {
    color: var(--white);
    border-color: var(--primary);
    background: var(--gradient);
    box-shadow: 0 0 24px rgba(4,255,183,0.3);
    transform: rotate(var(--angle)) translate(var(--radius)) scale(1.15);
  }

  .orbital-year {
    display: inline-block;
    transform: rotate(calc(-1 * var(--angle)));
    animation: counterSpin var(--orbit-duration) linear infinite;
  }

  @keyframes counterSpin {
    from { transform: rotate(calc(-1 * var(--angle))) rotate(0deg); }
    to   { transform: rotate(calc(-1 * var(--angle))) rotate(-360deg); }
  }

  @media (max-width: 900px) {
    .orbital-item {
      width: 52px;
      height: 52px;
      margin: -26px;
      font-size: 0.75rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .orbital-year {
      animation: none;
    }
  }
</style>