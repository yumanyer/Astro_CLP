<section class="hero" id="hero">
  <div class="hero-grid">
    <div class="hero-left reveal">
      <span class="badge">Comunidad Web3 de La Plata desde 2017</span>
      <h1>Construyendo el <span class="grad-text">ecosistema Web3</span> de La Plata</h1>
      <p class="hero-desc">
        Somos una comunidad tecnológica que conecta personas, proyectos e instituciones
        alrededor de la innovación, la descentralización y la educación.
      </p>
      <div class="hero-ctas">
        <a href="#contacto" class="btn btn-primary">Unirme a la Comunidad</a>
        <a href="#historia" class="btn btn-outline">Conocer nuestra historia</a>
      </div>
    </div>

    <div class="hero-right reveal">
      <div class="model-wrap" id="modelWrap">
        <div class="model-glow"></div>

        <canvas id="modelCanvas"></canvas>
        <div class="model-loading" id="modelLoading" role="img">Cargando modelo 3D…</div>
      </div>
    </div>
  </div>
</section>

<style>
.hero {
  max-width: 1600px;
  width: 100%;
  padding: 160px 5vw 100px;
  margin: 0 auto;
  box-sizing: border-box;
}

.hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
  justify-content: space-between;
}

.hero-left h1 {
  font-size: clamp(2.2rem, 5vw, 3.6rem);
  margin-bottom: 20px;
}

.hero-desc {
  color: var(--text-muted);
  max-width: 480px;
  margin-bottom: 32px;
}

.hero-ctas {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 56px;
}

.hero-right {
  position: relative;
}
.model-wrap {
  position: relative;
  aspect-ratio: 1/1;
  border-radius: var(--radius);
  border: 1px solid var(--glass-border);
  background: var(--glass-bg);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.model-glow {
  position: absolute;
  width: 70%; height: 70%;
  background: radial-gradient(circle, rgba(4,255,183,0.25), rgba(213,63,233,0.2) 60%, transparent 75%);
  filter: blur(40px);
  border-radius: 50%;
}
.model-wrap canvas {
  position: relative;
  width: 100%;
  height: 100%;
  display: block;
}
.model-loading {
  position: absolute;
  color: var(--text-muted);
  font-size: 0.85rem;
}
/* ============ RESPONSIVE GLOBAL ============ */
@media (max-width: 968px) {
  .hero-grid { grid-template-columns: 1fr; }
  .hero-right { order: -1; }
  .nav-links { display: none; }
  .nav-cta { display: none; }
  .burger { display: flex; }

  .nav-links.open {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 100%; left: 0; right: 0;
    background: rgba(8,8,8,0.95);
    backdrop-filter: blur(16px);
    padding: 24px 32px;
    gap: 20px;
    border-bottom: 1px solid var(--glass-border);
  }
}
@media (max-width: 600px) {
  .hero { padding: 130px 20px 60px; }
}
</style>

<script type="module">
  import * as THREE from 'three';
import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';

  // ============ MODELO 3D (Three.js + GLB) ============
const modelWrap = document.getElementById('modelWrap');
const canvas    = document.getElementById('modelCanvas');
const modelLoading = document.getElementById('modelLoading');

if (modelWrap && canvas) {
  const scene  = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(
    45, modelWrap.clientWidth / modelWrap.clientHeight, 0.1, 1000
  );
  camera.position.set(0, 0, 4);

  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
  renderer.setPixelRatio(window.devicePixelRatio);
  renderer.setSize(modelWrap.clientWidth, modelWrap.clientHeight);

  scene.add(new THREE.AmbientLight(0xffffff, 0.6));
  const dirLight = new THREE.DirectionalLight(0xffffff, 1.2);
  dirLight.position.set(5, 10, 7);
  scene.add(dirLight);

  let model;
  const loader = new GLTFLoader();
  loader.load(
    '1.glb',
    (gltf) => {
      model = gltf.scene;

      const box    = new THREE.Box3().setFromObject(model);
      const size   = box.getSize(new THREE.Vector3());
      const center = box.getCenter(new THREE.Vector3());
      model.position.sub(center);

      const maxDim = Math.max(size.x, size.y, size.z);
      model.scale.setScalar(2.2 / maxDim);

      scene.add(model);
      if (modelLoading) modelLoading.hidden = true;
    },
    undefined,
    (error) => {
      console.error('Error cargando el modelo GLB:', error);
      if (modelLoading) {
        modelLoading.textContent = 'No se pudo cargar el modelo 3D';
      }
    }
  );

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Estado de rotación ──────────────────────────────────────────
  const AUTO_SPEED   =  0.004;   // velocidad de auto-rotación Y
  const TILT_MIN     = -0.08;    // límite superior  (mirar desde arriba)
  const TILT_MAX     =  0.55;    // límite inferior  (nunca ver la base)
  const TILT_DEFAULT = 0.20;    // inclinación en reposo

  let rotY        = 0;           // acumulado eje Y (libre, 360°)
  let tiltX       = TILT_DEFAULT;// inclinación actual eje X
  let targetTiltX = TILT_DEFAULT;

  // ── Drag / Touch ────────────────────────────────────────────────
  let isDragging  = false;
  let lastX       = 0;
  let lastY       = 0;

  function onDragStart(x, y) {
    isDragging = true;
    lastX = x;
    lastY = y;
  }

  function onDragMove(x, y) {
    if (!isDragging) return;
    const dx = x - lastX;
    const dy = y - lastY;
    lastX = x;
    lastY = y;

    // Eje Y: libre, el arrastre horizontal suma/resta directamente
    rotY += dx * 0.008;

    // Eje X: limitado — arrastre vertical ajusta el tilt con clamp
    targetTiltX = Math.max(TILT_MIN, Math.min(TILT_MAX, targetTiltX + dy * 0.005));
  }

  function onDragEnd() {
    isDragging = false;
  }

  // Mouse
  modelWrap.addEventListener('mousedown',  (e) => onDragStart(e.clientX, e.clientY));
  window.addEventListener   ('mousemove',  (e) => onDragMove (e.clientX, e.clientY));
  window.addEventListener   ('mouseup',    ()  => onDragEnd());

  // Touch
  modelWrap.addEventListener('touchstart', (e) => {
    const t = e.touches[0];
    onDragStart(t.clientX, t.clientY);
  }, { passive: true });

  modelWrap.addEventListener('touchmove', (e) => {
    if (e.cancelable) e.preventDefault();
    const t = e.touches[0];
    onDragMove(t.clientX, t.clientY);
  }, { passive: false });

  modelWrap.addEventListener('touchend', onDragEnd);

  // Cursor
  modelWrap.style.cursor = 'grab';
  modelWrap.addEventListener('mousedown', () => modelWrap.style.cursor = 'grabbing');
  window.addEventListener   ('mouseup',   () => {
    if (modelWrap) modelWrap.style.cursor = 'grab';
  });

  // ── Loop de animación con IntersectionObserver ───────────────────
  let isModelVisible = true;
  const modelObserver = new IntersectionObserver((entries) => {
    isModelVisible = entries[0].isIntersecting;
  }, { threshold: 0 });
  modelObserver.observe(modelWrap);

  function animate() {
    requestAnimationFrame(animate);
    if (!model || !isModelVisible) return;

    // Y: auto-rotación siempre activa (el drag le suma su delta directamente)
    if (!reducedMotion) rotY += AUTO_SPEED;
    model.rotation.y = rotY;

    // X: interpolar suavemente hacia el tilt objetivo
    tiltX += (targetTiltX - tiltX) * 0.06;
    model.rotation.x = tiltX;

    renderer.render(scene, camera);
  }
  animate();

  // ── Resize ──────────────────────────────────────────────────────
  window.addEventListener('resize', () => {
    if (!modelWrap) return;
    renderer.setSize(modelWrap.clientWidth, modelWrap.clientHeight);
    camera.aspect = modelWrap.clientWidth / modelWrap.clientHeight;
    camera.updateProjectionMatrix();
  });
}

</script>