---
const orbitalData = {
  "2017": {
    title: "Primeros encuentros",
    text: "Nace la comunidad con meetups informales sobre blockchain.",
    media: [{type:'img', src:'/img/eventos/pizzaday.jpg'}]
  },
  "2018": {
    title: "Primeros talleres",
    text: "Charlas introductorias a Bitcoin y Ethereum en espacios universitarios.",
    media: [{type:'img', src:'/img/eventos/pizzaday.jpg'}]
  },
  "2019": {
    title: "Alianzas locales",
    text: "Primeras colaboraciones con espacios de coworking y hubs tech.",
    media: [{type:'img', src:'/img/eventos/pizzaday.jpg'}]
  },
  "2020": {
    title: "Eventos virtuales",
    text: "La comunidad migra a formatos online, sumando alcance nacional.",
    media: [{type:'img', src:'/img/eventos/pizzaday.jpg'}]
  },
  "2021": {
    title: "Boom Web3",
    text: "Crecimiento acelerado de miembros y primeras meetups masivas presenciales.",
    media: [{type:'img', src:'/img/eventos/pizzaday.jpg'}]
  },
  "2022": {
    title: "Educación formal",
    text: "Primeros cursos y programas educativos junto a universidades.",
    media: [{type:'img', src:'/img/eventos/pizzaday.jpg'}]
  },
  "2023": {
    title: "Red de voluntariado",
    text: "Se conforma la red de voluntariado tecnológico de la comunidad.",
    media: [{type:'img', src:'/img/eventos/pizzaday.jpg'}]
  },
  "2024": {
    title: "Eventos insignia",
    text: "Consolidación de eventos propios de referencia en la región.",
    media: [{type:'img', src:'/img/eventos/pizzaday.jpg'}]
  },
  "2025": {
    title: "Expansión institucional",
    text: "Nuevas alianzas con organizaciones, sponsors y protocolos.",
    media: [{type:'img', src:'/img/eventos/pizzaday.jpg'}]
  },
  "actualidad": {
    title: "Hacia el futuro",
    text: "Seguimos creciendo como referencia Web3 de La Plata.",
    media: [{type:'img', src:'/img/eventos/pizzaday.jpg'}]
  }
};

const years = Object.keys(orbitalData);
---

<section class="historia" id="historia">
  <div class="section-head reveal">
    <h2>Nuestra Historia</h2>
    <p>Desde 2017 construyendo comunidad, eventos y conocimiento Web3 en La Plata.</p>
  </div>

  <div class="orbital-wrap reveal">
    <div class="orbital-container" id="orbital">
      <img src="/img/icon/CLP-premium.webp" class="orbital-logo" width="180" height="180" alt="CLP" decoding="async">      
      <div class="orbital-ring">
        {years.map((year, index) => {
          const angle = (index * (360 / years.length)) + 198;
          return (
            <button 
              class={`orbital-item ${year === '2017' ? 'active' : ''}`} 
              data-year={year} 
              style={`--angle:${angle}deg`}
            >
              <span class="orbital-year">{year === 'actualidad' ? 'Hoy' : year}</span>
            </button>
          )
        })}
      </div>
    </div>

    <div class="orbital-info" id="orbitalInfo">
      <span class="info-year" id="infoYear">2017</span>
      <h3 id="infoTitle">Primeros encuentros</h3>
      <p id="infoText">Nace la comunidad con meetups informales sobre blockchain.</p>
      <div class="info-media" id="infoMedia"></div>
    </div>
  </div>
</section>

<script define:vars={{ orbitalData }}>
  const orbitalInfo = document.getElementById('orbitalInfo');
  const infoYear = document.getElementById('infoYear');
  const infoTitle = document.getElementById('infoTitle');
  const infoText = document.getElementById('infoText');
  const infoMedia = document.getElementById('infoMedia');
  const items = document.querySelectorAll('.orbital-item');

  items.forEach(item => {
    item.addEventListener('click', () => {
      const year = item.getAttribute('data-year');
      const data = orbitalData[year];

      items.forEach(i => i.classList.remove('active'));
      item.classList.add('active');

      orbitalInfo.classList.remove('fade');
      void orbitalInfo.offsetWidth; // trigger reflow
      orbitalInfo.classList.add('fade');

      infoYear.textContent = year === 'actualidad' ? 'Hoy' : year;
      infoTitle.textContent = data.title;
      infoText.textContent = data.text;
      
      infoMedia.innerHTML = '';
      data.media.forEach(m => {
        if (m.type === 'img') {
          const img = document.createElement('img');
          img.src = m.src;
          img.style.width = '80px';
          img.style.borderRadius = '8px';
          infoMedia.appendChild(img);
        }
      });
    });
  });
</script>

<style>
  .historia { padding: 100px 0; }

  .orbital-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    margin: 0 auto;
    padding: 0 32px;
  }

  .orbital-container {
    --size: clamp(380px, 45vw, 560px);
    --radius: calc(var(--size) / 2 - 50px);
    --orbit-duration: 90s;
    position: relative;
    width: var(--size);
    height: var(--size);
    margin: 0 auto;
    border-radius: 50%;
    border: 1px dashed var(--glass-border);
  }

  .orbital-logo {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 90px;
    height: 90px;
    object-fit: contain;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    filter: drop-shadow(0 0 24px rgba(4,255,183,0.25));
    z-index: 2;
  }

  .orbital-ring {
    position: absolute;
    inset: 0;
    animation: orbitSpin var(--orbit-duration) linear infinite;
  }

  .orbital-container:hover .orbital-ring,
  .orbital-container:hover .orbital-year {
    animation-play-state: paused;
  }

  @keyframes orbitSpin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .orbital-item {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 64px;
    height: 64px;
    margin: -32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: blur(8px);
    color: var(--text-muted);
    font-family: var(--font-title);
    font-weight: 700;
    font-size: 0.85rem;
    cursor: pointer;
    transition: border-color 0.25s ease, color 0.25s ease, background 0.25s ease, transform 0.25s ease;
    transform: rotate(var(--angle)) translate(var(--radius));
  }

  .orbital-item:hover {
    color: var(--white);
    border-color: var(--primary);
  }

  .orbital-item.active {
    color: var(--white);
    border-color: var(--primary);
    background: var(--gradient);
    box-shadow: 0 0 24px rgba(4,255,183,0.3);
    transform: rotate(var(--angle)) translate(var(--radius)) scale(1.15);
  }

  .orbital-year {
    display: inline-block;
    transform: rotate(calc(-1 * var(--angle)));
    animation: counterSpin var(--orbit-duration) linear infinite;
  }
  @keyframes counterSpin {
    from { transform: rotate(calc(-1 * var(--angle))) rotate(0deg); }
    to   { transform: rotate(calc(-1 * var(--angle))) rotate(-360deg); }
  }

  .orbital-info {
    padding: 32px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(8px);
    min-height: 280px;
  }

  .info-year {
    display: inline-block;
    font-family: var(--font-title);
    font-weight: 700;
    font-size: 1.4rem;
    margin-bottom: 12px;
    background: var(--gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .orbital-info h3 { font-size: 1.2rem; margin-bottom: 12px; }
  .orbital-info p { font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; }

  .info-media {
    margin-top: 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .orbital-info.fade {
    animation: fadeInfo 0.3s ease;
  }
  @keyframes fadeInfo {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 900px) {
    .orbital-wrap {
      grid-template-columns: 1fr;
      gap: 60px;
    }
    .orbital-container {
      --size: min(90vw, 420px);
    }
    .orbital-item {
      width: 52px;
      height: 52px;
      margin: -26px;
      font-size: 0.75rem;
    }
  }
</style>
