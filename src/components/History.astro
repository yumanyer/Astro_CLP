    text: "Nace la comunidad con meetups informales sobre blockchain.",
    media: [
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}]},
  "2018": {
    title: "Primeros talleres",
    text: "Charlas introductorias a Bitcoin y Ethereum en espacios universitarios.",
    media: [
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}]},
  "2019": {
    title: "Alianzas locales",
    text: "Primeras colaboraciones con espacios de coworking y hubs tech.",
    media: [
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}]},
  "2020": {
    title: "Eventos virtuales",
    text: "La comunidad migra a formatos online, sumando alcance nacional.",
    media: [
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}]},
  "2021": {
    title: "Boom Web3",
    text: "Crecimiento acelerado de miembros y primeras meetups masivas presenciales.",
    media: [
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}]},
  "2022": {
    title: "Educación formal",
    text: "Primeros cursos y programas educativos junto a universidades.",
    media: [
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}]},
  "2023": {
    title: "Red de voluntariado",
    text: "Se conforma la red de voluntariado tecnológico de la comunidad.",
    media: [
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}]  },
  "2024": {
    title: "Eventos insignia",
    text: "Consolidación de eventos propios de referencia en la región.",
    media: [
      {type:'img', src:'img/year/2024_1.webp'}, 
      {type:'img', src:'img/year/2024_2.webp'}, 
      {type:'img', src:'img/year/2024_3.webp'},]
  },
  "2025": {
    title: "Expansión institucional",
    text: "Nuevas alianzas con organizaciones, sponsors y protocolos.",
    media: [
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}]},
  "actualidad": {
    title: "Hacia el futuro",
    text: "Seguimos creciendo como referencia Web3 de La Plata.",
    media: [
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}, 
      {type:'img', src:'img/year/2024_1.jpg'}]}
};

const years = Object.keys(orbitalData);
---

<section class="historia" id="historia">
  <div class="section-head reveal">
    <h2>Nuestra Historia</h2>
    <p>Desde 2017 construyendo comunidad, eventos y conocimiento Web3 en La Plata.</p>
  </div>

  <div class="orbital-wrap reveal">
    <div class="orbital-container" id="orbital">
      <img src="/img/icon/CLP-premium.webp" class="orbital-logo" width="180" height="180" alt="CLP" decoding="async">      
      <div class="orbital-ring">
        {years.map((year, index) => {
          const angle = (index * (360 / years.length)) + 198;
          return (
            <OrbitalItem 
              year={year} 
              angle={angle} 
              active={year === '2017'} 
            />
          )
        })}
      </div>
    </div>

    <div class="orbital-info" id="orbitalInfo">
      <span class="info-year" id="infoYear">2017</span>
      <h3 id="infoTitle">Primeros encuentros</h3>
      <p id="infoText">Nace la comunidad con meetups informales sobre blockchain.</p>
      <div class="info-media" id="infoMedia">
        <!-- Las imágenes aquí ahora abrirán el StoryViewer -->
      </div>
    </div>
  </div>

  <!-- Componente StoryViewer (Modal oculto) -->
  <StoryViewer />
</section>

<script define:vars={{ orbitalData }}>
  const orbitalInfo = document.getElementById('orbitalInfo');
  const infoYear = document.getElementById('infoYear');
  const infoTitle = document.getElementById('infoTitle');
  const infoText = document.getElementById('infoText');
  const infoMedia = document.getElementById('infoMedia');
  const items = document.querySelectorAll('.orbital-item');

  function updateInfoPanel(year) {
    const data = orbitalData[year];
    
    orbitalInfo.classList.remove('fade');
    void orbitalInfo.offsetWidth; // trigger reflow
    orbitalInfo.classList.add('fade');

    infoYear.textContent = year === 'actualidad' ? 'Hoy' : year;
    infoTitle.textContent = data.title;
    infoText.textContent = data.text;
    
    infoMedia.innerHTML = '';
    data.media.forEach((m, index) => {
      if (m.type === 'img') {
        const img = document.createElement('img');
        img.src = m.src;
        img.className = 'info-thumb';
        img.title = "Click para ver historia";
        
        // Al hacer clic en la miniatura, disparamos el evento para abrir el StoryViewer
        img.addEventListener('click', () => {
          const event = new CustomEvent('open-stories', {
            detail: {
              stories: data.media,
              startIndex: index
            }
          });
          window.dispatchEvent(event);
        });
        
        infoMedia.appendChild(img);
      }
    });
  }

  items.forEach(item => {
    item.addEventListener('click', () => {
      const year = item.getAttribute('data-year');
      items.forEach(i => i.classList.remove('active'));
      item.classList.add('active');
      updateInfoPanel(year);
    });
  });

  // Inicializar el primer año
  updateInfoPanel("2017");
</script>

<style is:global>
  .orbital-container {
    --size: clamp(380px, 45vw, 560px);
    --radius: calc(var(--size) / 2 - 50px);
    --orbit-duration: 90s;
  }
</style>

<style>
  .historia { padding: 100px 0; position: relative; }

  .orbital-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    margin: 0 auto;
    padding: 0 32px;
  }

  .orbital-container {
    position: relative;
    width: var(--size);
    height: var(--size);
    margin: 0 auto;
    border-radius: 50%;
    border: 1px dashed var(--glass-border);
  }

  .orbital-logo {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 90px;
    height: 90px;
    object-fit: contain;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    filter: drop-shadow(0 0 24px rgba(4,255,183,0.25));
    z-index: 2;
  }

  .orbital-ring {
    position: absolute;
    inset: 0;
    animation: orbitSpin var(--orbit-duration) linear infinite;
  }

  .orbital-container:hover .orbital-ring,
  .orbital-container:hover .orbital-item .orbital-year {
    animation-play-state: paused;
  }

  @keyframes orbitSpin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .orbital-info {
    padding: 32px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(8px);
    min-height: 280px;
  }

  .info-year {
    display: inline-block;
    font-family: var(--font-title);
    font-weight: 700;
    font-size: 1.4rem;
    margin-bottom: 12px;
    background: var(--gradient);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .orbital-info h3 { font-size: 1.2rem; margin-bottom: 12px; }
  .orbital-info p { font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; }

  .info-media {
    margin-top: 20px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  :global(.info-thumb) {
    width: 80px;
    height: 80px;
    object-fit: cover;
    border-radius: 8px;
    cursor: pointer;
    transition: transform 0.2s ease, border-color 0.2s ease;
    border: 2px solid transparent;
  }

  :global(.info-thumb:hover) {
    transform: scale(1.05);
    border-color: var(--primary);
  }

  .orbital-info.fade {
    animation: fadeInfo 0.3s ease;
  }
  @keyframes fadeInfo {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 900px) {
    .orbital-wrap {
      grid-template-columns: 1fr;
      gap: 60px;
    }
  }
</style>