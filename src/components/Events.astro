<section class="eventos" id="eventos">
  <div class="section-head reveal">
    <h2>Eventos</h2>
    <p>Explorá nuestras actividades pasadas y próximas.</p>
  </div>

  <div class="eventos-dashboard reveal">
    <div class="eventos-list" role="tablist" aria-label="Lista de eventos">
      {eventos.map((ev, i) => (
        <button 
          class={`evento-item ${i === 0 ? 'active' : ''}`} 
          data-index={i} 
          role="tab" 
          aria-selected={i === 0 ? "true" : "false"}
        >
          <span class="evento-icon">◆</span>
          <span class="evento-info">
            <strong>{ev.titulo}</strong>
            <small>{ev.fecha}</small>
          </span>
        </button>
      ))}
    </div>

    <div class="eventos-panel">
      {eventos.map((ev, i) => (
        <div 
          class={`evento-panel-content ${i === 0 ? 'active' : ''}`} 
          role="tabpanel" 
          hidden={i !== 0}
        >
          <div class="evento-text">
            <h3>{ev.titulo}</h3>
            <p>{ev.descripcion}</p>
            <span class="evento-loc">📍 {ev.ubicacion}</span>
          </div>
          <div class="evento-media">
            <div class="evento-img">
              <img src={ev.img} alt={ev.titulo} loading="lazy" />
            </div>
            <span class="evento-fecha">📅 {ev.fecha}</span>
            <a href={ev.luma} target="_blank" rel="noopener noreferrer" class="btn btn-outline evento-cta">
              Ver en Luma ↗
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
/* ============ EVENTOS ============ */
.eventos { padding: 60px 32px 100px;  margin: 0 auto; }
.eventos-dashboard {
  display: grid;
  grid-template-columns: 1fr 1.6fr;
  gap: 24px;
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius);
  padding: 24px;
  backdrop-filter: blur(8px);
}
.eventos-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.evento-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 16px;
  border-radius: 12px;
  border: 1px solid transparent;
  background: transparent;
  color: var(--white);
  text-align: left;
  cursor: pointer;
  transition: background 0.2s ease, border-color 0.2s ease;
  font-family: var(--font-body);
}
.evento-item:hover { background: rgba(255,255,255,0.04); }
.evento-item.active {
  background: rgba(4,255,183,0.06);
  border-left: 3px solid var(--primary);
}
.evento-icon { color: var(--primary); font-size: 0.9rem; }
.evento-info { display: flex; flex-direction: column; }
.evento-info small { color: var(--text-muted); font-size: 0.78rem; margin-top: 2px; }

.eventos-panel { position: relative; }

/* ----- Panel de detalle: texto a la izquierda / media apilada a la derecha ----- */
.evento-panel-content {
  display: grid;
  grid-template-columns: 1fr 300px;
  grid-template-rows: auto auto 1fr;
  column-gap: 36px;
  row-gap: 16px;
  animation: fadeIn 0.4s ease;
}
.evento-panel-content[hidden] {
  display: none;
}
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

.evento-text {
  grid-column: 1;
  grid-row: 1 / 4;
  display: flex;
  flex-direction: column;
}

.evento-media {
  grid-column: 2;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

/* Imagen del evento en el panel */
.evento-img {
  height: 220px;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--glass-border);
  background: linear-gradient(135deg, rgba(4,255,183,0.12), rgba(213,63,233,0.12));
}
.evento-img img{
  width:100%;
  height:100%;
  object-position:center top;
}

/* Fecha del evento (junto a la imagen) */
.evento-fecha {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 16px;
  border-radius: 10px;
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--white);
}

/* CTA Luma */
.evento-cta {
  display: inline-flex;
  justify-content: center;
  width: 100%;
}

.evento-panel-content h3 { font-size: 1.4rem; margin-bottom: 8px; }
.evento-panel-content p {
  color: var(--text-muted);
  margin-bottom: 12px;
  white-space: pre-line;
  max-height: 260px;
  overflow-y: auto;
  padding-right: 10px;
  scrollbar-width: thin;
  scrollbar-color: var(--glass-border) transparent;
}
.evento-panel-content p::-webkit-scrollbar { width: 4px; }
.evento-panel-content p::-webkit-scrollbar-track { background: transparent; }
.evento-panel-content p::-webkit-scrollbar-thumb { background: var(--glass-border); border-radius: 99px; }
.evento-loc { display: block; font-size: 0.85rem; color: var(--text-muted); margin-top: auto; }

/* Lista scrolleable cuando hay muchos eventos */
.eventos-list {
  max-height: 420px;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--glass-border) transparent;
}
.eventos-list::-webkit-scrollbar {
  width: 4px;
}
.eventos-list::-webkit-scrollbar-track {
  background: transparent;
}
.eventos-list::-webkit-scrollbar-thumb {
  background: var(--glass-border);
  border-radius: 99px;
}

@media (max-width: 768px) {
  .eventos-dashboard { grid-template-columns: 1fr; }
}

@media (max-width: 640px) {
  .evento-panel-content {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto auto auto;
  }
  .evento-text { grid-column: 1; grid-row: 2; }
  .evento-media { grid-column: 1; grid-row: 1; }
  .evento-img { height: 200px; }
}
</style>

<script>
  function initEventos() {
    const list = document.querySelector('.eventos-list');
    const panel = document.querySelector('.eventos-panel');
    if (!list || !panel) return;

    const items    = list.querySelectorAll('.evento-item');
    const contents = panel.querySelectorAll<HTMLElement>('.evento-panel-content');

    list.addEventListener('click', (e) => {
      const tab = (e.target as Element).closest<HTMLElement>('.evento-item');
      if (!tab) return;

      const index = parseInt(tab.dataset.index ?? '0', 10);

      items.forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      contents.forEach(p => {
        p.classList.remove('active');
        p.hidden = true;
      });

      const activePanel = contents[index];
      if (activePanel) {
        activePanel.hidden = false;
        activePanel.classList.add('active');
      }

      tab.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    });
  }

  document.addEventListener('DOMContentLoaded', initEventos);
</script>
